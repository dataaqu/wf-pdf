generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  pdfHistories PdfHistory[]
}

model Company {
  id        String   @id @default(cuid())
  name      String
  taxId     String
  createdAt DateTime @default(now())
}

model PdfHistory {
  id            String   @id @default(cuid())
  userId        String
  type          String
  invoiceNumber String?
  fileName      String
  htmlContent   String
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([invoiceNumber])
}
